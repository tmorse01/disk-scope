{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "module": "CommonJS",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": ".tsbuild/main",
    "types": [
      "node"
    ]
  },
  "include": [
    "src/main/**/*.ts",
    "src/shared/**/*.ts",
    "src/scanner/**/*.ts",
    "forge.env.d.ts"
  ]
}
