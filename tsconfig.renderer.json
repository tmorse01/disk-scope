{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "noEmit": false,
    "outDir": ".tsbuild/renderer",
    "types": ["vite/client"],
    "experimentalDecorators": true,
    "useDefineForClassFields": false
  },
  "include": ["src/renderer/**/*.ts", "src/shared/**/*.ts"]
}
